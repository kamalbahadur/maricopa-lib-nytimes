# Copy this file to secrets.env and fill in your values.
# secrets.env is git-ignored and never committed.

# Required: from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Required at run time: the Google account email you will log in with
GOOGLE_EMAIL=you@example.com

